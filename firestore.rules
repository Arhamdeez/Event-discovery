rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email in [
          'admin@raunaq.com',
          'l226619@lhr.nu.edu.pk',
          'l226994@lhr.nu.edu.pk'
        ];
    }

    function isEventParticipant(eventId) {
      return signedIn()
        && (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/attended/$(eventId))
          || (
            exists(/databases/$(database)/documents/events/$(eventId))
            && get(/databases/$(database)/documents/events/$(eventId)).data.organizerId == request.auth.uid
          )
          || isAdmin()
        );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /users/{userId}/createdEvents/{eventId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    match /users/{userId}/attended/{eventId} {
      allow read, write: if isOwner(userId);
    }
    match /users/{userId}/followers/{followerId} {
      allow read: if isOwner(userId) || isOwner(followerId) || isAdmin();
      allow create: if isOwner(followerId)
        && request.resource.data.uid == followerId
        && request.resource.data.organizerId == userId;
      allow delete: if isOwner(followerId);
    }
    match /users/{userId}/following/{organizerId} {
      allow read: if isOwner(userId) || isOwner(organizerId) || isAdmin();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.organizerId == organizerId;
      allow delete: if isOwner(userId);
    }

    // Public feed (Explore / landing / shareable links). Anyone can read; only owner can write.
    match /events/{eventId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.organizerId == request.auth.uid;
      allow delete: if signedIn()
        && (resource.data.organizerId == request.auth.uid || isAdmin());

      // Organizer can edit full event details.
      allow update: if signedIn()
        && (resource.data.organizerId == request.auth.uid || isAdmin());

      // Any signed-in user can RSVP by incrementing attendeeCount only.
      allow update: if signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['attendeeCount', 'updatedAt'])
        && request.resource.data.attendeeCount is int
        && (
          request.resource.data.attendeeCount
            == ((resource.data.attendeeCount is int) ? resource.data.attendeeCount : 0) + 1
          || (
            ((resource.data.attendeeCount is int) ? resource.data.attendeeCount : 0) > 0
            && request.resource.data.attendeeCount
              == ((resource.data.attendeeCount is int) ? resource.data.attendeeCount : 0) - 1
          )
        );

      match /messages/{messageId} {
        allow read: if isEventParticipant(eventId);
        allow create: if isEventParticipant(eventId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.senderEmail is string
          && request.resource.data.senderName is string
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 800;
        allow update, delete: if false;
      }
    }
  }
}
